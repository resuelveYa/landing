{
  "redirects": [
    {
      "source": "/:path*",
      "has": [
        {
          "type": "host",
          "value": "www.resuelveya.cl"
        }
      ],
      "destination": "https://resuelveya.cl/:path*",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/budget/(.*)",
      "destination": "https://resuelveya-budget.vercel.app/budget/$1"
    },
    {
      "source": "/budget",
      "destination": "https://resuelveya-budget.vercel.app/budget"
    },
    {
      "source": "/cashflow/(.*)",
      "destination": "https://resuelveya-cashflow.vercel.app/cashflow/$1"
    },
    {
      "source": "/cashflow",
      "destination": "https://resuelveya-cashflow.vercel.app/cashflow"
    }
  ]
}